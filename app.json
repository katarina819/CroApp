{
  "expo": {
    "name": "VARA",
    "slug": "vara",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vara",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.cromapmobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "VARA koristi tvoju lokaciju za prikaz restorana, kafića, plaža i drugih zanimljivih mjesta u tvojoj blizini.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "VARA koristi tvoju lokaciju za prikaz restorana, kafića, plaža i drugih zanimljivih mjesta u tvojoj blizini, čak i kada aplikacija radi u pozadini.",
        "CFBundleURLTypes": [
          // ← dodaj ovo za iOS deep links
          {
            "CFBundleURLSchemes": ["vara"]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B3F0E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "navigationBar": {
        "backgroundColor": "#1a2e1a",
        "barStyle": "light-content"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ],
      "package": "com.anonymous.cromapmobile",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAzgl_HOUh-kwD_eQQaWLerARekr36qrgg"
        }
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "vara",
              "host": "*"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1B3F0E",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "VARA koristi tvoju lokaciju za prikaz restorana, kafića, plaža i drugih zanimljivih mjesta u tvojoj blizini.",
          "locationWhenInUsePermission": "VARA koristi tvoju lokaciju za prikaz restorana, kafića, plaža i drugih zanimljivih mjesta u tvojoj blizini.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 34,
            "buildToolsVersion": "35.0.0",
            "kotlinVersion": "2.1.0",
            "minSdkVersion": 24
          }
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
